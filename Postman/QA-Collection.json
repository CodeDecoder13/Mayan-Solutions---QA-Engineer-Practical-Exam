{
  "info": {
    "_postman_id": "qa-technical-assessment",
    "name": "QA Technical Assessment",
    "description": "API test collection for JSONPlaceholder endpoints as part of the QA Engineer Technical Assessment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users"]
            },
            "description": "Retrieve all users from the API. Expected: Status 200 with an array of 10 users."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array of users', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    pm.expect(jsonData.length).to.eql(10);",
                  "});",
                  "",
                  "pm.test('Each user has required fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(function(user) {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('name');",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user).to.have.property('username');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Edge Case - Get Users with Invalid Query Param",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users?id=invalid",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users"],
              "query": [
                {
                  "key": "id",
                  "value": "invalid"
                }
              ]
            },
            "description": "Edge Case: Send an invalid query parameter. Expected: Status 200 with an empty array."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an empty array for invalid filter', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    pm.expect(jsonData.length).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GET User by ID",
      "item": [
        {
          "name": "Get User by ID 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users/1",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users", "1"]
            },
            "description": "Retrieve a specific user by ID. Expected: Status 200 with user data for Leanne Graham."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User data is correct', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.eql(1);",
                  "    pm.expect(jsonData.name).to.eql('Leanne Graham');",
                  "    pm.expect(jsonData.username).to.eql('Bret');",
                  "    pm.expect(jsonData.email).to.eql('Sincere@april.biz');",
                  "});",
                  "",
                  "pm.test('User has address and company', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('address');",
                  "    pm.expect(jsonData).to.have.property('company');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Edge Case - Get User 999 (Non-existent)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users/999",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users", "999"]
            },
            "description": "Edge Case: Request a user that does not exist. Expected: Status 404 with empty object."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 for non-existent user', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Response body is empty object', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(Object.keys(jsonData).length).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "POST Create Post",
      "item": [
        {
          "name": "Create New Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"QA Test Post\",\n  \"body\": \"Testing API endpoint\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/posts",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["posts"]
            },
            "description": "Create a new post. Expected: Status 201 with the created post data including an id."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Post created with correct data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.title).to.eql('QA Test Post');",
                  "    pm.expect(jsonData.body).to.eql('Testing API endpoint');",
                  "    pm.expect(jsonData.userId).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Post has an ID assigned', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Edge Case - Create Post with Empty Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/posts",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["posts"]
            },
            "description": "Edge Case: Create a post with an empty body. Expected: Status 201 (mock API accepts it) but no title/body fields."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 (mock API accepts empty body)', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Post is created with an ID but no content', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "PUT Update Post",

        },
        {
          "name": "Edge Case - Update Non-existent Post 999",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Ghost Post\",\n  \"body\": \"This post does not exist\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/posts/999",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["posts", "999"]
            },
            "description": "Edge Case: Attempt to update a post that does not exist. Expected: Error response (500)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns error for non-existent post', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 500]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}

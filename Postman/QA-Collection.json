              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Post\",\n  \"body\": \"Updated content\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/posts/1",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["posts", "1"]
            },
            "description": "Update an existing post. Expected: Status 200 with updated post data."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Post updated with correct data', function () {",
                  "    const jsonData = pm.response.json();",
